# Copy to .env and fill in values for local development

# Postgres connection (matches docker-compose.yml defaults)
DATABASE_URL=postgres://merchanthub:password@localhost:5433/merchanthub_development

# tessera-core service URL and internal API key
TESSERA_CORE_URL=http://localhost:4000
TESSERA_INTERNAL_API_KEY=dev-internal-api-key

# MerchantHub demo seed data
DEMO_MERCHANT_ID=merch_demo
DEMO_USER_PASSWORD=password123!
