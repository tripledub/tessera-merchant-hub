<div id="extraction-progress"
     data-controller="extraction-progress"
     data-extraction-progress-total-value="<%= total %>"
     class="mb-4 rounded-lg border border-gray-200 bg-gray-50 p-3 dark:border-gray-800 dark:bg-gray-900/50">
  <div class="mb-1 flex justify-between text-sm">
    <span class="text-gray-600 dark:text-gray-400" data-extraction-progress-target="label">
      Extracting documents...
    </span>
    <span class="font-medium text-gray-800 dark:text-white/90" data-extraction-progress-target="counter">
      0 of <%= total %>
    </span>
  </div>
  <div class="h-2 overflow-hidden rounded-full bg-gray-200 dark:bg-gray-700">
    <div data-extraction-progress-target="bar"
         class="h-full rounded-full bg-brand-500 transition-all duration-500 ease-out"
         style="width: 0%">
    </div>
  </div>
</div>
