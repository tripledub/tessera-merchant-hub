<tr id="<%= dom_id(document, :entity_doc) %>" class="hover:bg-gray-50 dark:hover:bg-white/[0.03]">
  <td class="py-2 pr-4 font-medium text-gray-900 dark:text-white/90 truncate max-w-xs">
    <%= document.file.filename %>
  </td>
  <td class="px-4 py-2">
    <% if document.document_type.present? %>
      <span class="badge badge-info"><%= t("kyc.documents.document_types.#{document.document_type}") %></span>
    <% else %>
      <span class="text-gray-400">—</span>
    <% end %>
  </td>
  <td class="px-4 py-2 text-theme-sm text-gray-500 dark:text-gray-400">
    <%= document.created_at.strftime("%-d %b %Y") %>
  </td>
  <td class="py-2 pl-4">
    <%= button_to kyc_corporate_entity_entity_document_link_path(corporate_entity, document),
          method: :delete,
          title: t("kyc.corporate_entities.show.unlink"),
          class: "text-gray-400 hover:text-error-500 dark:hover:text-error-400" do %>
      <svg class="fill-current" width="18" height="18" viewBox="0 0 24 24">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M17.293 6.293a1 1 0 0 1 1.414 1.414L13.414 12l5.293 5.293a1 1 0 0 1-1.414 1.414L12 13.414l-5.293 5.293a1 1 0 0 1-1.414-1.414L10.586 12 5.293 6.707a1 1 0 0 1 1.414-1.414L12 10.586l5.293-5.293z"/>
      </svg>
    <% end %>
  </td>
</tr>
