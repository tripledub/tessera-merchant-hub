<%= form_with model: kyc_principal,
              url: kyc_principal.persisted? ? kyc_principal_path(kyc_principal) : applicant_kyc_principals_path(kyc_principal.applicant),
              class: "space-y-4" do |f| %>
  <%= render "shared/error_messages", object: kyc_principal %>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :name, t("kyc.principals.form.fields.name"), class: "form-label" %>
      <%= f.text_field :name, class: "form-input", required: true %>
    </div>

    <div>
      <%= f.label :role, t("kyc.principals.form.fields.role"), class: "form-label" %>
      <%= f.select :role,
            KycPrincipal.roles.keys.map { |r| [t("applicants.show.principals.roles.#{r}"), r] },
            {},
            class: "form-input" %>
    </div>

    <div>
      <%= f.label :date_of_birth, t("kyc.principals.form.fields.date_of_birth"), class: "form-label" %>
      <%= f.date_field :date_of_birth, class: "form-input" %>
    </div>

    <div>
      <%= f.label :email, t("kyc.principals.form.fields.email"), class: "form-label" %>
      <%= f.email_field :email, class: "form-input" %>
    </div>
  </div>

  <div class="border-t border-gray-100 pt-4">
    <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t("kyc.principals.form.sections.address") %></p>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= f.label :address_line1, t("kyc.principals.form.fields.address_line1"), class: "form-label" %>
        <%= f.text_field :address_line1, class: "form-input" %>
      </div>

      <div class="sm:col-span-2">
        <%= f.label :address_line2, t("kyc.principals.form.fields.address_line2"), class: "form-label" %>
        <%= f.text_field :address_line2, class: "form-input" %>
      </div>

      <div>
        <%= f.label :city, t("kyc.principals.form.fields.city"), class: "form-label" %>
        <%= f.text_field :city, class: "form-input" %>
      </div>

      <div>
        <%= f.label :postcode, t("kyc.principals.form.fields.postcode"), class: "form-label" %>
        <%= f.text_field :postcode, class: "form-input" %>
      </div>

      <div class="sm:col-span-2">
        <%= f.label :country, t("kyc.principals.form.fields.country"), class: "form-label" %>
        <%= f.text_field :country, class: "form-input" %>
      </div>
    </div>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit t("kyc.principals.form.submit"), class: "btn-primary" %>
    <% if local_assigns[:modal] %>
      <button type="button" data-action="click->modal#close" class="btn-secondary">
        <%= t("kyc.principals.form.cancel") %>
      </button>
    <% else %>
      <%= link_to t("kyc.principals.form.cancel"), applicant_path(kyc_principal.applicant), class: "btn-secondary" %>
    <% end %>
  </div>
<% end %>
