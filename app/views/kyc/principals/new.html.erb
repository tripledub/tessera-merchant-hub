<% content_for :title, t('.page_title') %>

<turbo-frame id="principal-modal">
  <div data-controller="modal" data-modal-frame-value="principal-modal"
       data-action="keydown.esc@window->modal#close"
       class="fixed inset-0 z-50 flex items-center justify-center">
    <%# Backdrop %>
    <div data-action="click->modal#close" class="absolute inset-0 bg-gray-900/50 backdrop-blur-sm"></div>

    <%# Modal card %>
    <div class="relative z-10 w-full max-w-md rounded-2xl border border-gray-200 bg-white p-6 shadow-xl dark:border-gray-800 dark:bg-gray-900"
         data-action="click->modal#nothing">
      <div class="mb-5 flex items-center justify-between">
        <h2 class="text-base font-semibold text-gray-900 dark:text-white"><%= t('.title') %></h2>
        <button type="button" data-action="click->modal#close"
                class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
          <svg class="fill-current" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M5.293 5.293a1 1 0 0 1 1.414 0L12 10.586l5.293-5.293a1 1 0 1 1 1.414 1.414L13.414 12l5.293 5.293a1 1 0 0 1-1.414 1.414L12 13.414l-5.293 5.293a1 1 0 0 1-1.414-1.414L10.586 12 5.293 6.707a1 1 0 0 1 0-1.414z" fill=""/>
          </svg>
        </button>
      </div>

      <%= render "form", kyc_principal: kyc_principal, modal: true %>
    </div>
  </div>
</turbo-frame>
