<%= form_with model: applicant, class: "space-y-4" do |f| %>
  <%= render "shared/error_messages", object: applicant %>

  <div>
    <%= f.label :name, t("applicants.form.fields.name"), class: "form-label" %>
    <%= f.text_field :name, class: "form-input", required: true %>
  </div>

  <div>
    <%= f.label :company_name, t("applicants.form.fields.company_name"), class: "form-label" %>
    <%= f.text_field :company_name, class: "form-input" %>
  </div>

  <div>
    <%= f.label :contact_email, t("applicants.form.fields.contact_email"), class: "form-label" %>
    <%= f.email_field :contact_email, class: "form-input" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :country, t("applicants.form.fields.country"), class: "form-label" %>
      <%= f.text_field :country, class: "form-input", placeholder: "United Kingdom" %>
    </div>
    <div>
      <%= f.label :country_code, t("applicants.form.fields.country_code"), class: "form-label" %>
      <%= f.text_field :country_code, class: "form-input", placeholder: "GB", maxlength: 2 %>
    </div>
  </div>

  <div>
    <%= f.label :address_line1, t("applicants.form.fields.address_line1"), class: "form-label" %>
    <%= f.text_field :address_line1, class: "form-input" %>
  </div>

  <div>
    <%= f.label :city, t("applicants.form.fields.city"), class: "form-label" %>
    <%= f.text_field :city, class: "form-input" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit t("applicants.form.submit"), class: "btn-primary" %>
    <%= link_to t("applicants.form.cancel"), applicants_path, class: "btn-secondary" %>
  </div>
<% end %>
