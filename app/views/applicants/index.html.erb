<% content_for :title, t('.page_title') %>

<div class="mb-6 flex items-center justify-between">
  <h1 class="text-xl font-semibold text-gray-900 dark:text-white/90"><%= t('.title') %></h1>
  <% if policy(Applicant).new? %>
    <%= link_to t('.new_applicant'), new_applicant_path, class: "btn-primary" %>
  <% end %>
</div>

<div class="card">
  <%= form_with url: applicants_path, method: :get,
        data: { controller: "filter", turbo_frame: "applicants-table" },
        class: "mb-4" do %>
    <div class="flex items-center gap-3">
      <div class="relative flex-1 max-w-sm">
        <input type="search" name="q" value="<%= params[:q] %>"
               placeholder="<%= t('.search_placeholder') %>"
               class="form-input pl-9"
               data-action="input->filter#submitDebounced" />
        <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-gray-400">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
          </svg>
        </span>
      </div>
    </div>
  <% end %>

  <%= turbo_frame_tag "applicants-table" do %>
    <table class="w-full text-left text-theme-sm">
      <thead>
        <tr class="border-b border-gray-200 dark:border-gray-800">
          <th class="py-3 pr-4 font-medium text-gray-500 border-r border-gray-100 dark:border-gray-800 dark:text-gray-400"><%= t('.table.name') %></th>
          <th class="px-4 py-3 font-medium text-gray-500 border-r border-gray-100 dark:border-gray-800 dark:text-gray-400"><%= t('.table.company') %></th>
          <th class="px-4 py-3 font-medium text-gray-500 border-r border-gray-100 dark:border-gray-800 dark:text-gray-400"><%= t('.table.status') %></th>
          <th class="px-4 py-3 font-medium text-gray-500 dark:text-gray-400"><%= t('.table.created') %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
        <% if @applicants.empty? %>
          <tr>
            <td colspan="4" class="py-10 text-center text-theme-sm text-gray-500 dark:text-gray-400">
              <%= t('.table.empty') %>
            </td>
          </tr>
        <% else %>
          <% @applicants.each do |a| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-white/[0.03]">
              <td class="py-3 pr-4 font-medium text-gray-900 border-r border-gray-100 dark:border-gray-800 dark:text-white/90">
                <%= link_to a.name, applicant_path(a),
                      class: "text-brand-600 hover:text-brand-700 hover:underline dark:text-brand-400 dark:hover:text-brand-300",
                      data: { turbo_frame: "_top" } %>
              </td>
              <td class="px-4 py-3 text-gray-500 border-r border-gray-100 dark:border-gray-800 dark:text-gray-400">
                <%= a.company_name.presence || "—" %>
              </td>
              <td class="px-4 py-3 border-r border-gray-100 dark:border-gray-800">
                <% if a.pending? %>
                  <span class="badge badge-warning"><%= t(".table.statuses.#{a.status}") %></span>
                <% elsif a.approved? %>
                  <span class="badge badge-success"><%= t(".table.statuses.#{a.status}") %></span>
                <% else %>
                  <span class="badge badge-error"><%= t(".table.statuses.#{a.status}") %></span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-gray-500 dark:text-gray-400">
                <%= a.created_at.strftime("%d %b %Y") %>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>

    <% if @pagy.pages > 1 %>
      <div class="mt-4 border-t border-gray-200 pt-4">
        <%== @pagy.series_nav %>
      </div>
    <% end %>
  <% end %>
</div>
