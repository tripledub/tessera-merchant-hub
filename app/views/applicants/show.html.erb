<% content_for :title, applicant.name %>

<div class="mb-4">
  <%= link_to t('.back'), applicants_path, class: "text-theme-sm font-medium text-brand-600 hover:text-brand-700" %>
</div>

<div class="mb-6 flex items-start justify-between">
  <div>
    <h1 class="text-xl font-semibold text-gray-900"><%= applicant.name %></h1>
    <% if applicant.company_name.present? %>
      <p class="mt-0.5 text-theme-sm text-gray-400"><%= applicant.company_name %></p>
    <% end %>
  </div>
  <% if policy(applicant).edit? %>
    <%= link_to t('.edit'), edit_applicant_path(applicant), class: "btn-secondary" %>
  <% end %>
</div>

<%# Principals %>
<div class="card mb-6">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500">
      <%= t('.sections.principals') %>
    </h2>
    <% if policy(KycPrincipal).new? %>
      <%= link_to t('.add_principal'), new_applicant_kyc_principal_path(applicant), class: "btn-secondary" %>
    <% end %>
  </div>

  <% if @kyc_principals.empty? %>
    <p class="text-theme-sm text-gray-500"><%= t('.principals.empty') %></p>
  <% else %>
    <table class="w-full text-left text-theme-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="py-2 pr-4 font-medium text-gray-500 border-r border-gray-100"><%= t('.principals.table.name') %></th>
          <th class="px-4 py-2 font-medium text-gray-500 border-r border-gray-100"><%= t('.principals.table.role') %></th>
          <th class="px-4 py-2 font-medium text-gray-500"><%= t('.principals.table.actions') %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @kyc_principals.each do |p| %>
          <tr class="hover:bg-gray-50">
            <td class="py-2 pr-4 font-medium text-gray-900 border-r border-gray-100"><%= p.name %></td>
            <td class="px-4 py-2 text-gray-600 border-r border-gray-100">
              <%= t(".principals.roles.#{p.role}") %>
            </td>
            <td class="px-4 py-2">
              <div class="flex items-center gap-3">
                <% if policy(p).edit? %>
                  <%= link_to edit_kyc_principal_path(p), title: t('.principals.edit'),
                        class: "text-gray-400 hover:text-brand-500 dark:hover:text-brand-400" do %>
                    <svg class="fill-current" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M15.232 5.232l3.536 3.536M9 11l6.536-6.536a2 2 0 0 1 2.828 0l.172.172a2 2 0 0 1 0 2.828L12 14H9v-3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                      <path d="M3 21h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  <% end %>
                <% end %>
                <% if policy(p).destroy? %>
                  <%= button_to kyc_principal_path(p), method: :delete,
                        title: t('.principals.delete'),
                        data: { turbo_confirm: t('.principals.delete_confirm', name: p.name) },
                        class: "text-gray-400 hover:text-error-500 dark:hover:text-error-400" do %>
                    <svg class="fill-current" width="18" height="18" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M7.04142 4.29199C7.04142 3.04935 8.04878 2.04199 9.29142 2.04199H11.7081C12.9507 2.04199 13.9581 3.04935 13.9581 4.29199V4.54199H16.1252H17.166C17.5802 4.54199 17.916 4.87778 17.916 5.29199C17.916 5.70621 17.5802 6.04199 17.166 6.04199H16.8752V8.74687V13.7469V16.7087C16.8752 17.9513 15.8678 18.9587 14.6252 18.9587H6.37516C5.13252 18.9587 4.12516 17.9513 4.12516 16.7087V13.7469V8.74687V6.04199H3.8335C3.41928 6.04199 3.0835 5.70621 3.0835 5.29199C3.0835 4.87778 3.41928 4.54199 3.8335 4.54199H4.87516H7.04142V4.29199ZM15.3752 13.7469V8.74687V6.04199H13.9581H13.2081H7.79142H7.04142H5.62516V8.74687V13.7469V16.7087C5.62516 17.1229 5.96095 17.4587 6.37516 17.4587H14.6252C15.0394 17.4587 15.3752 17.1229 15.3752 16.7087V13.7469ZM8.54142 4.54199H12.4581V4.29199C12.4581 3.87778 12.1223 3.54199 11.7081 3.54199H9.29142C8.87721 3.54199 8.54142 3.87778 8.54142 4.29199V4.54199ZM8.8335 8.50033C9.24771 8.50033 9.5835 8.83611 9.5835 9.25033V14.2503C9.5835 14.6645 9.24771 15.0003 8.8335 15.0003C8.41928 15.0003 8.0835 14.6645 8.0835 14.2503V9.25033C8.0835 8.83611 8.41928 8.50033 8.8335 8.50033ZM12.9168 9.25033C12.9168 8.83611 12.581 8.50033 12.1668 8.50033C11.7526 8.50033 11.4168 8.83611 11.4168 9.25033V14.2503C11.4168 14.6645 11.7526 15.0003 12.1668 15.0003C12.581 15.0003 12.9168 14.6645 12.9168 14.2503V9.25033Z" fill=""/>
                    </svg>
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<%# Documents %>
<div class="card">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500">
      <%= t('.sections.documents') %>
    </h2>
  </div>

  <%= turbo_stream_from "applicant_#{applicant.id}_documents" %>

  <% if @kyc_documents.empty? %>
    <p class="text-theme-sm text-gray-500 mb-4"><%= t('.documents.empty') %></p>
  <% else %>
    <div class="space-y-2 mb-4">
      <% @kyc_documents.each do |doc| %>
        <%= turbo_frame_tag "kyc_document_#{doc.id}" do %>
          <%= render "kyc_documents/kyc_document", document: doc %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if policy(KycDocument).create? %>
    <div id="kyc-upload" class="mt-4 border-t border-gray-200 pt-4">
      <%= form_with url: applicant_kyc_documents_path(applicant),
            data: { controller: "dropzone", "dropzone-url-value": rails_direct_uploads_url } do %>
        <div data-dropzone-target="zone"
             class="flex flex-col items-center justify-center rounded-lg border-2 border-dashed border-gray-300 p-6 text-center cursor-pointer"
             data-action="click->dropzone#browse dragover->dropzone#dragover dragleave->dropzone#dragleave drop->dropzone#drop">
          <svg class="h-8 w-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
          </svg>
          <p class="text-theme-sm text-gray-500"><%= t('.documents.drag_or_click') %></p>
          <input type="file" multiple accept="image/*,application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/csv"
                 data-dropzone-target="input"
                 data-action="change->dropzone#pick"
                 class="hidden" />
        </div>
        <ul class="mt-3 space-y-1" data-dropzone-target="list"></ul>
        <button type="button"
                data-dropzone-target="submit"
                data-action="click->dropzone#submit"
                class="mt-3 btn-primary">
          <%= t('.documents.upload_button') %>
        </button>
      <% end %>
    </div>
  <% end %>
</div>
