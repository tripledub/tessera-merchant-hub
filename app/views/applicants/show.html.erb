<% content_for :title, applicant.name %>

<%# Modal frame for Add/Edit Principal %>
<turbo-frame id="principal-modal"></turbo-frame>

<div class="mb-4">
  <%= link_to t('.back'), applicants_path, class: "text-theme-sm font-medium text-brand-600 hover:text-brand-700" %>
</div>

<div class="mb-6 flex items-start justify-between">
  <div>
    <h1 class="text-xl font-semibold text-gray-900 dark:text-white/90"><%= applicant.name %></h1>
    <% if applicant.company_name.present? %>
      <p class="mt-0.5 text-theme-sm text-gray-400"><%= applicant.company_name %></p>
    <% end %>
  </div>
  <% if policy(applicant).edit? %>
    <%= link_to t('.edit'), edit_applicant_path(applicant), class: "btn-secondary" %>
  <% end %>
</div>

<div data-controller="tabs" data-tabs-default-value="overview">
  <%# Tab navigation — underline with icon style (tailadmin tab-03) %>
  <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
    <div class="border-b border-gray-200 px-4 sm:px-6 dark:border-gray-800">
      <nav class="-mb-px flex space-x-2 overflow-x-auto [&::-webkit-scrollbar-thumb]:rounded-full [&::-webkit-scrollbar-thumb]:bg-gray-200 dark:[&::-webkit-scrollbar-thumb]:bg-gray-600 dark:[&::-webkit-scrollbar-track]:bg-transparent [&::-webkit-scrollbar]:h-1.5">
        <%= render "applicants/tab_button", tab: "overview", label: t('.tabs.overview'), icon: "grid" %>
        <%= render "applicants/tab_button", tab: "principals", label: t('.tabs.principals'), icon: "users" %>
        <%= render "applicants/tab_button", tab: "documents", label: t('.tabs.documents'), icon: "document" %>
        <%= render "applicants/tab_button", tab: "ownership", label: t('.tabs.ownership'), icon: "sitemap" %>
        <%= render "applicants/tab_button", tab: "compliance", label: t('.tabs.compliance'), icon: "shield" %>
      </nav>
    </div>

    <%# Tab panels %>
    <div class="p-4 sm:p-6">
      <div data-tabs-target="panel" data-tab="overview" data-tab-src="<%= tab_applicant_path(applicant, tab: 'overview') %>">
        <div id="overview-tab-content">
          <%= render "applicants/tabs/overview", applicant: applicant %>
        </div>
      </div>

      <div data-tabs-target="panel" data-tab="principals" hidden>
        <%= render "applicants/tabs/principals", applicant: applicant %>
      </div>

      <div data-tabs-target="panel" data-tab="documents" hidden>
        <%= render "applicants/tabs/documents", applicant: applicant %>
      </div>

      <div data-tabs-target="panel" data-tab="ownership" hidden data-tab-src="<%= tab_applicant_path(applicant, tab: 'ownership') %>">
        <div id="ownership-tab-content">
          <%= render "applicants/tabs/ownership", applicant: applicant %>
        </div>
      </div>

      <div data-tabs-target="panel" data-tab="compliance" hidden data-tab-src="<%= tab_applicant_path(applicant, tab: 'compliance') %>">
        <div id="compliance-tab-content">
          <%= render "applicants/tabs/compliance", applicant: applicant %>
        </div>
      </div>
    </div>
  </div>
</div>
