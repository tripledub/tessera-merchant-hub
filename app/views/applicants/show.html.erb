<% content_for :title, applicant.name %>

<div class="mb-4">
  <%= link_to t('.back'), applicants_path, class: "text-theme-sm font-medium text-brand-600 hover:text-brand-700" %>
</div>

<div class="mb-6 flex items-start justify-between">
  <div>
    <h1 class="text-xl font-semibold text-gray-900"><%= applicant.name %></h1>
    <% if applicant.company_name.present? %>
      <p class="mt-0.5 text-theme-sm text-gray-400"><%= applicant.company_name %></p>
    <% end %>
  </div>
  <% if policy(applicant).edit? %>
    <%= link_to t('.edit'), edit_applicant_path(applicant), class: "btn-secondary text-theme-sm" %>
  <% end %>
</div>

<%# Principals %>
<div class="card mb-6">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500">
      <%= t('.sections.principals') %>
    </h2>
    <% if policy(KycPrincipal).new? %>
      <%= link_to t('.add_principal'), new_applicant_kyc_principal_path(applicant), class: "btn-secondary text-theme-sm" %>
    <% end %>
  </div>

  <% if @kyc_principals.empty? %>
    <p class="text-theme-sm text-gray-500"><%= t('.principals.empty') %></p>
  <% else %>
    <table class="w-full text-left text-theme-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="py-2 pr-4 font-medium text-gray-500 border-r border-gray-100"><%= t('.principals.table.name') %></th>
          <th class="px-4 py-2 font-medium text-gray-500 border-r border-gray-100"><%= t('.principals.table.role') %></th>
          <th class="px-4 py-2 font-medium text-gray-500"><%= t('.principals.table.actions') %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @kyc_principals.each do |p| %>
          <tr class="hover:bg-gray-50">
            <td class="py-2 pr-4 font-medium text-gray-900 border-r border-gray-100"><%= p.name %></td>
            <td class="px-4 py-2 text-gray-600 border-r border-gray-100">
              <%= t(".principals.roles.#{p.role}") %>
            </td>
            <td class="px-4 py-2 flex gap-2">
              <% if policy(p).edit? %>
                <%= link_to t('.principals.edit'), edit_kyc_principal_path(p), class: "text-brand-600 hover:underline text-xs" %>
              <% end %>
              <% if policy(p).destroy? %>
                <%= button_to t('.principals.delete'), kyc_principal_path(p), method: :delete,
                      data: { turbo_confirm: t('.principals.delete_confirm', name: p.name) },
                      class: "text-red-600 hover:underline text-xs bg-transparent border-0 p-0 cursor-pointer" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<%# Documents %>
<div class="card">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500">
      <%= t('.sections.documents') %>
    </h2>
  </div>

  <%= turbo_stream_from "applicant_#{applicant.id}_documents" %>

  <% if @kyc_documents.empty? %>
    <p class="text-theme-sm text-gray-500 mb-4"><%= t('.documents.empty') %></p>
  <% else %>
    <div class="space-y-2 mb-4">
      <% @kyc_documents.each do |doc| %>
        <%= turbo_frame_tag "kyc_document_#{doc.id}" do %>
          <%= render "kyc_documents/kyc_document", document: doc %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if policy(KycDocument).create? %>
    <div id="kyc-upload" class="mt-4 border-t border-gray-200 pt-4">
      <%= form_with url: applicant_kyc_documents_path(applicant),
            data: { controller: "dropzone", "dropzone-url-value": rails_direct_uploads_url } do %>
        <div data-dropzone-target="zone"
             class="flex flex-col items-center justify-center rounded-lg border-2 border-dashed border-gray-300 p-6 text-center cursor-pointer"
             data-action="click->dropzone#pick:prevent">
          <svg class="h-8 w-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
          </svg>
          <p class="text-theme-sm text-gray-500"><%= t('.documents.drag_or_click') %></p>
          <input type="file" multiple accept="image/*,application/pdf"
                 data-dropzone-target="input"
                 data-action="change->dropzone#pick"
                 class="hidden" />
        </div>
        <ul class="mt-3 space-y-1" data-dropzone-target="list"></ul>
        <button type="button"
                data-dropzone-target="submit"
                data-action="click->dropzone#submit"
                class="mt-3 btn-primary text-theme-sm">
          <%= t('.documents.upload_button') %>
        </button>
      <% end %>
    </div>
  <% end %>
</div>
