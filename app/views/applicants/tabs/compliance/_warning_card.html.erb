<div id="warning_<%= warning.id %>" class="rounded-lg border p-4 <%= warning.acknowledged? ? 'border-gray-200 bg-gray-50 opacity-60 dark:border-gray-800 dark:bg-gray-900/50' : 'border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]' %>">
  <div class="flex items-start justify-between">
    <div class="flex items-start gap-3">
      <div class="mt-0.5">
        <%= presenter.warning_type_badge(warning) %>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-800 dark:text-white/90">
          <%= warning.message %>
        </p>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
          <%= presenter.warning_detail(warning) %>
        </p>
        <% if warning.corporate_entity.present? %>
          <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">
            Entity: <%= warning.corporate_entity.name %>
          </p>
        <% end %>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <% if warning.acknowledged? %>
        <span class="text-xs text-gray-400 dark:text-gray-500"><%= t('applicants.tabs.compliance.acknowledged') %></span>
      <% else %>
        <%= button_to kyc_validation_warning_path(warning), method: :patch,
              class: "text-gray-400 hover:text-success-500 dark:hover:text-success-400",
              title: t('applicants.tabs.compliance.acknowledge') do %>
          <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M20.707 5.293a1 1 0 0 1 0 1.414l-11 11a1 1 0 0 1-1.414 0l-5-5a1 1 0 1 1 1.414-1.414L9 15.586 19.293 5.293a1 1 0 0 1 1.414 0z"/>
          </svg>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
