<%# Overview tab — applicant details and compliance summary via ApplicantPresenter %>
<% present(applicant) do |p| %>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div>
      <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
        <%= t('.details') %>
      </h3>
      <dl class="space-y-2">
        <% p.detail_rows.each do |row| %>
          <div class="flex justify-between">
            <dt class="text-theme-sm font-medium text-gray-500 dark:text-gray-400"><%= row[:label] %></dt>
            <dd class="text-theme-sm text-gray-800 dark:text-white/90"><%= row[:value] %></dd>
          </div>
        <% end %>
        <div class="flex justify-between">
          <dt class="text-theme-sm font-medium text-gray-500 dark:text-gray-400"><%= t('.status') %></dt>
          <dd><%= p.status_badge %></dd>
        </div>
      </dl>
    </div>

    <div>
      <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
        <%= t('.summary') %>
      </h3>
      <div class="grid grid-cols-2 gap-3">
        <a href="#principals" class="rounded-lg border border-gray-200 p-3 hover:bg-gray-50 dark:border-gray-800 dark:hover:bg-white/[0.03] transition-colors"
           data-action="click->tabs#select" data-tab="principals">
          <p class="text-2xl font-semibold text-gray-800 dark:text-white/90"><%= p.principal_count %></p>
          <p class="text-theme-sm text-gray-500 dark:text-gray-400"><%= t('.principals_count') %></p>
        </a>
        <a href="#documents" class="rounded-lg border border-gray-200 p-3 hover:bg-gray-50 dark:border-gray-800 dark:hover:bg-white/[0.03] transition-colors"
           data-action="click->tabs#select" data-tab="documents">
          <p class="text-2xl font-semibold text-gray-800 dark:text-white/90"><%= p.document_count %></p>
          <p class="text-theme-sm text-gray-500 dark:text-gray-400"><%= t('.documents_count') %></p>
        </a>
        <a href="#ownership" class="rounded-lg border border-gray-200 p-3 hover:bg-gray-50 dark:border-gray-800 dark:hover:bg-white/[0.03] transition-colors"
           data-action="click->tabs#select" data-tab="ownership">
          <p class="text-2xl font-semibold text-gray-800 dark:text-white/90"><%= p.entity_count %></p>
          <p class="text-theme-sm text-gray-500 dark:text-gray-400"><%= t('.entities_count') %></p>
        </a>
        <a href="#compliance" class="rounded-lg border border-gray-200 p-3 hover:bg-gray-50 dark:border-gray-800 dark:hover:bg-white/[0.03] transition-colors"
           data-action="click->tabs#select" data-tab="compliance">
          <p class="text-2xl font-semibold <%= p.warning_count_class %>"><%= p.warning_count %></p>
          <p class="text-theme-sm text-gray-500 dark:text-gray-400"><%= t('.warnings_count') %></p>
        </a>
      </div>
    </div>
  </div>
<% end %>
