<%# KYC completeness radial chart — MH-137 %>
<% chart_data = calculator.as_chart_json %>

<div class="mt-6">
  <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
    <%= t('.kyc_completeness') %>
  </h3>
  <div class="rounded-2xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-white/[0.03]"
       data-controller="radial-chart"
       data-radial-chart-overall-value="<%= chart_data[:overall] %>"
       data-radial-chart-dimensions-value="<%= chart_data[:dimensions].to_json %>">
    <div class="flex flex-col items-center lg:flex-row lg:items-start lg:gap-8">
      <div data-radial-chart-target="chart" class="w-full max-w-[280px] shrink-0"></div>
      <div data-radial-chart-target="breakdown" class="mt-4 w-full space-y-3 lg:mt-6"></div>
    </div>
  </div>
</div>
