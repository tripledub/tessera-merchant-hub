<%# Compliance tab — validation warnings via Kyc::CompliancePresenter %>
<% present(applicant, Kyc::CompliancePresenter) do |p| %>
  <% if p.has_warnings? %>
    <%# Summary stats %>
    <div class="mb-6 grid grid-cols-2 gap-3 sm:grid-cols-5">
      <div class="rounded-lg border border-gray-200 p-3 dark:border-gray-800">
        <p class="text-2xl font-semibold text-gray-800 dark:text-white/90"><%= p.total_count %></p>
        <p class="text-theme-sm text-gray-500 dark:text-gray-400"><%= t('.total') %></p>
      </div>
      <div class="rounded-lg border border-gray-200 p-3 dark:border-gray-800">
        <p class="text-2xl font-semibold <%= p.unacknowledged_count > 0 ? 'text-red-600 dark:text-red-400' : 'text-gray-800 dark:text-white/90' %>">
          <%= p.unacknowledged_count %>
        </p>
        <p class="text-theme-sm text-gray-500 dark:text-gray-400"><%= t('.unacknowledged') %></p>
      </div>
      <div class="rounded-lg border border-gray-200 p-3 dark:border-gray-800">
        <p class="text-2xl font-semibold text-amber-600 dark:text-amber-400"><%= p.count_by_type(:percentage_deviation) %></p>
        <p class="text-theme-sm text-gray-500 dark:text-gray-400"><%= t('.deviations') %></p>
      </div>
      <div class="rounded-lg border border-gray-200 p-3 dark:border-gray-800">
        <p class="text-2xl font-semibold text-red-600 dark:text-red-400"><%= p.count_by_type(:nominee_detected) %></p>
        <p class="text-theme-sm text-gray-500 dark:text-gray-400"><%= t('.nominees') %></p>
      </div>
      <div class="rounded-lg border border-gray-200 p-3 dark:border-gray-800">
        <p class="text-2xl font-semibold text-blue-600 dark:text-blue-400"><%= p.count_by_type(:ubo_threshold_exceeded) %></p>
        <p class="text-theme-sm text-gray-500 dark:text-gray-400"><%= t('.ubos') %></p>
      </div>
    </div>

    <%# Warning cards %>
    <div class="space-y-3">
      <% p.warnings.each do |warning| %>
        <%= render "applicants/tabs/compliance/warning_card", warning: warning, presenter: p %>
      <% end %>
    </div>
  <% else %>
    <div class="py-8 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>
      </svg>
      <h3 class="mt-2 text-sm font-semibold text-gray-800 dark:text-white/90"><%= t('.empty_title') %></h3>
      <p class="mt-1 text-theme-sm text-gray-500 dark:text-gray-400"><%= t('.empty_description') %></p>
    </div>
  <% end %>
<% end %>
