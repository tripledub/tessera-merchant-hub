<% content_for :title, t('.page_title') %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-xl font-semibold text-gray-900"><%= t('.title') %></h1>
    <p class="mt-1 text-theme-sm text-gray-500"><%= t('.subtitle') %></p>
  </div>
  <%= link_to t('.invite'), new_team_path,
        class: "inline-flex items-center gap-2 rounded-lg bg-brand-500 px-4 py-2.5 text-theme-sm font-medium text-white shadow-theme-xs hover:bg-brand-600" %>
</div>

<div class="overflow-hidden rounded-xl border border-gray-200 bg-white dark:border-white/[0.05] dark:bg-white/[0.03]">
  <table class="w-full text-left text-theme-sm">
    <thead>
      <tr class="border-b border-gray-100 dark:border-white/[0.05]">
        <th class="px-5 py-3 font-medium text-gray-500 dark:text-gray-400"><%= t('.table.email') %></th>
        <th class="px-5 py-3 font-medium text-gray-500 dark:text-gray-400"><%= t('.table.role') %></th>
        <th class="px-5 py-3 font-medium text-gray-500 dark:text-gray-400"><%= t('.table.status') %></th>
        <th class="px-5 py-3 font-medium text-gray-500 dark:text-gray-400"><%= t('.table.last_sign_in') %></th>
        <th class="px-5 py-3 font-medium text-gray-500 dark:text-gray-400"><%= t('.table.actions') %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-white/[0.05]">
      <% if team_members.empty? %>
        <tr>
          <td colspan="5" class="px-5 py-10 text-center text-theme-sm text-gray-500">
            <%= t('.table.empty') %>
          </td>
        </tr>
      <% else %>
        <% team_members.each do |member| %>
          <tr class="hover:bg-gray-50 dark:hover:bg-white/[0.02]">
            <td class="px-5 py-4 text-gray-800 dark:text-white/90"><%= member.email %></td>
            <td class="px-5 py-4 text-gray-500 dark:text-gray-400"><%= member.role.humanize %></td>
            <td class="px-5 py-4">
              <% if member.deactivated? %>
                <span class="badge badge-error"><%= t('.status.deactivated') %></span>
              <% elsif member.access_locked? %>
                <span class="badge badge-warning"><%= t('.status.locked') %></span>
              <% else %>
                <span class="badge badge-success"><%= t('.status.active') %></span>
              <% end %>
            </td>
            <td class="px-5 py-4 text-gray-500 dark:text-gray-400">
              <%= member.last_sign_in_at&.strftime("%d %b %Y") || t('.table.never') %>
            </td>
            <td class="px-5 py-4">
              <% if member != current_user && !member.deactivated? %>
                <%= button_to team_path(member),
                      method: :delete,
                      class: "table-action-danger",
                      title: t('.deactivate'),
                      data: { turbo_confirm: t('.deactivate_confirm', email: member.email) } do %>
                  <svg class="fill-current" width="18" height="18" viewBox="0 0 21 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M7.4163 3.79199C7.4163 2.54935 8.42366 1.54199 9.6663 1.54199H12.083C13.3256 1.54199 14.333 2.54935 14.333 3.79199V4.04199H16.5H17.5409C17.9551 4.04199 18.2909 4.37778 18.2909 4.79199C18.2909 5.20621 17.9551 5.54199 17.5409 5.54199H17.25V8.24687V13.2469V16.2087C17.25 17.4513 16.2427 18.4587 15 18.4587H6.75004C5.5074 18.4587 4.50004 17.4513 4.50004 16.2087V13.2469V8.24687V5.54199H4.20837C3.79416 5.54199 3.45837 5.20621 3.45837 4.79199C3.45837 4.37778 3.79416 4.04199 4.20837 4.04199H5.25004H7.4163V3.79199ZM15.75 13.2469V8.24687V5.54199H14.333H13.583H8.1663H7.4163H6.00004V8.24687V13.2469V16.2087C6.00004 16.6229 6.33583 16.9587 6.75004 16.9587H15C15.4143 16.9587 15.75 16.6229 15.75 16.2087V13.2469ZM8.9163 4.04199H12.833V3.79199C12.833 3.37778 12.4972 3.04199 12.083 3.04199H9.6663C9.25209 3.04199 8.9163 3.37778 8.9163 3.79199V4.04199ZM9.20837 8.00033C9.62259 8.00033 9.95837 8.33611 9.95837 8.75033V13.7503C9.95837 14.1645 9.62259 14.5003 9.20837 14.5003C8.79416 14.5003 8.45837 14.1645 8.45837 13.7503V8.75033C8.45837 8.33611 8.79416 8.00033 9.20837 8.00033ZM13.2917 8.75033C13.2917 8.33611 12.9559 8.00033 12.5417 8.00033C12.1275 8.00033 11.7917 8.33611 11.7917 8.75033V13.7503C11.7917 14.1645 12.1275 14.5003 12.5417 14.5003C12.9559 14.5003 13.2917 14.1645 13.2917 13.7503V8.75033Z" fill=""/>
                  </svg>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
