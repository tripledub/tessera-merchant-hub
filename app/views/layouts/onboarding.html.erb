<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "KYC onboarding" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script>
      (function () {
        var isDark = true;
        try {
          var stored = localStorage.getItem("darkMode");
          if (stored !== null) { isDark = JSON.parse(stored); }
        } catch (e) {}
        window.__darkMode = isDark;
        document.documentElement.classList.toggle("dark", isDark);
      })();
    </script>
  </head>

  <body class="bg-gray-50 font-outfit antialiased dark:bg-gray-950">
    <div class="flex min-h-screen flex-col">
      <header class="border-b border-gray-200 bg-white px-4 py-3 dark:border-gray-800 dark:bg-gray-900">
        <div class="mx-auto flex max-w-5xl items-center justify-between gap-4">
          <%= link_to portal_root_path, class: "flex items-center gap-3" do %>
            <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand-500 text-white">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                <path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm0 2v2h16V6H4zm0 4v8h16v-8H4zm2 2h4v2H6v-2z"/>
              </svg>
            </span>
            <span class="text-base font-semibold text-gray-900 dark:text-white/90">Tessera</span>
          <% end %>

          <div class="flex min-w-0 items-center gap-3">
            <span class="hidden truncate text-sm text-gray-600 dark:text-gray-400 sm:block"><%= current_applicant_user.email %></span>
            <%= link_to "Sign out", destroy_applicant_user_session_path,
                  data: { turbo_method: :delete },
                  class: "shrink-0 text-sm font-medium text-brand-600 hover:text-brand-700 hover:underline" %>
          </div>
        </div>
      </header>

      <main class="flex flex-1 px-3 py-4 sm:px-6 lg:px-8">
        <div class="mx-auto flex w-full max-w-5xl">
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
