<% content_for :title, @shop.name %>

<div class="max-w-2xl">
  <%# Back link %>
  <div class="mb-6">
    <%= link_to t('.back'), shops_path,
          class: "text-theme-sm font-medium text-brand-600 hover:text-brand-700" %>
  </div>

  <%# Page header %>
  <div class="mb-6 flex items-start justify-between gap-4">
    <h1 class="text-xl font-semibold text-gray-900"><%= @shop.name %></h1>
    <% if ShopPolicy.new(current_user, @shop).update? %>
      <%= link_to t('.edit'), edit_shop_path(@shop), class: "btn-secondary shrink-0" %>
    <% end %>
  </div>

  <%# Detail grid %>
  <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div class="card">
      <dt class="text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.fields.shop_id') %></dt>
      <dd class="mt-1 text-theme-sm font-mono text-gray-900"><%= @shop.shop_id %></dd>
    </div>

    <div class="card">
      <dt class="text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.fields.territory') %></dt>
      <dd class="mt-1 text-theme-sm text-gray-900"><%= @shop.country.presence || "—" %></dd>
    </div>

    <div class="card">
      <dt class="text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.fields.mode') %></dt>
      <dd class="mt-2">
        <span class="<%= @shop.test_mode? ? 'badge badge-warning' : 'badge badge-success' %>">
          <%= @shop.test_mode? ? t('shops.index.table.test') : t('shops.index.table.live') %>
        </span>
      </dd>
    </div>

    <div class="card sm:col-span-2">
      <dt class="text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.fields.notification_url') %></dt>
      <dd class="mt-1 text-theme-sm text-gray-900 break-all">
        <%= @shop.notification_url.presence || t('.fields.not_set') %>
      </dd>
    </div>
  </dl>

  <%= render "shops/credentials", shop: @shop %>
</div>
