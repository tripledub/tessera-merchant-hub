<% content_for :title, "Shops" %>

<div class="sm:flex sm:items-center mb-6">
  <div class="sm:flex-auto">
    <h1 class="text-2xl font-semibold text-gray-900">Shops</h1>
  </div>
</div>

<div class="overflow-x-auto -mx-4 sm:mx-0">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Shop ID</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Territory</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Mode</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Notification URL</th>
        <th class="relative px-4 py-3"><span class="sr-only">View</span></th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @shops.each do |shop| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 text-sm font-mono text-gray-900"><%= shop.shop_id %></td>
          <td class="px-4 py-3 text-sm text-gray-900"><%= shop.name %></td>
          <td class="px-4 py-3 text-sm text-gray-500"><%= shop.country.presence || "—" %></td>
          <td class="px-4 py-3 text-sm">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
              <%= shop.test_mode? ? 'bg-yellow-100 text-yellow-800' : 'bg-green-100 text-green-800' %>">
              <%= shop.test_mode? ? "Test" : "Live" %>
            </span>
          </td>
          <td class="px-4 py-3 text-sm text-gray-500 truncate max-w-xs">
            <%= shop.notification_url.presence || "—" %>
          </td>
          <td class="px-4 py-3 text-sm text-right whitespace-nowrap">
            <%= link_to "View", shop_path(shop), class: "table-action" %>
          </td>
        </tr>
      <% end %>
      <% if @shops.empty? %>
        <tr>
          <td colspan="6" class="px-4 py-8 text-center text-sm text-gray-500">No shops found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
