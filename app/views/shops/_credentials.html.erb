<section class="mt-8 border-t border-gray-200 pt-8">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-base font-semibold text-gray-900"><%= t('.title') %></h2>
      <p class="mt-0.5 text-theme-sm text-gray-500">
        <%= t('.subtitle') %>
      </p>
    </div>
    <% if ShopPolicy.new(current_user, shop).generate_credential? %>
      <%= button_to t('.generate'),
            shop_credential_path(shop),
            method: :post,
            class: "btn-primary shrink-0",
            data: { turbo_confirm: t('.generate_confirm') } %>
    <% end %>
  </div>

  <% if defined?(@credentials_error) && @credentials_error.present? %>
    <p class="mt-4 text-theme-sm text-error-600"><%= t('.load_error', message: @credentials_error) %></p>
  <% elsif @credentials.blank? %>
    <p class="mt-4 text-theme-sm text-gray-500"><%= t('.no_credentials') %></p>
  <% else %>
    <div class="mt-4 card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.table.public_key') %></th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.table.status') %></th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.table.signing') %></th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.table.created') %></th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.table.last_used') %></th>
              <th class="relative px-4 py-3"><span class="sr-only"><%= t('.table.actions') %></span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            <% @credentials.each do |cred| %>
              <% revoked = cred["status"].to_s == "revoked" %>
              <% credential_id = cred["id"].presence || cred["pk"] %>
              <tr>
                <td class="px-4 py-3 text-theme-sm font-mono text-gray-900"><%= cred["pk"] %></td>
                <td class="px-4 py-3">
                  <span class="<%= revoked ? 'badge badge-gray' : 'badge badge-success' %>">
                    <%= cred["status"].presence&.titleize || t('.table.unknown_status') %>
                  </span>
                </td>
                <td class="px-4 py-3 text-theme-sm text-gray-700">
                  <%= cred["signing_required"] ? t('.table.signing_required') : t('.table.signing_optional') %>
                </td>
                <td class="px-4 py-3 text-theme-sm text-gray-500"><%= cred["created"].presence || "—" %></td>
                <td class="px-4 py-3 text-theme-sm text-gray-500"><%= cred["last_used"].presence || "—" %></td>
                <td class="px-4 py-3 text-center">
                  <% if !revoked && ShopPolicy.new(current_user, shop).revoke_credential? %>
                    <%= button_to shop_credential_revoke_path(shop, credential_id),
                          method: :delete,
                          class: "table-action-danger",
                          title: t('.revoke'),
                          form: { "aria-label": t('.revoke') },
                          data: { turbo_confirm: t('.revoke_confirm', pk: cred['pk']) } do %>
                      <svg class="fill-current" width="18" height="18" viewBox="0 0 21 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M7.4163 3.79199C7.4163 2.54935 8.42366 1.54199 9.6663 1.54199H12.083C13.3256 1.54199 14.333 2.54935 14.333 3.79199V4.04199H16.5H17.5409C17.9551 4.04199 18.2909 4.37778 18.2909 4.79199C18.2909 5.20621 17.9551 5.54199 17.5409 5.54199H17.25V8.24687V13.2469V16.2087C17.25 17.4513 16.2427 18.4587 15 18.4587H6.75004C5.5074 18.4587 4.50004 17.4513 4.50004 16.2087V13.2469V8.24687V5.54199H4.20837C3.79416 5.54199 3.45837 5.20621 3.45837 4.79199C3.45837 4.37778 3.79416 4.04199 4.20837 4.04199H5.25004H7.4163V3.79199ZM15.75 13.2469V8.24687V5.54199H14.333H13.583H8.1663H7.4163H6.00004V8.24687V13.2469V16.2087C6.00004 16.6229 6.33583 16.9587 6.75004 16.9587H15C15.4143 16.9587 15.75 16.6229 15.75 16.2087V13.2469ZM8.9163 4.04199H12.833V3.79199C12.833 3.37778 12.4972 3.04199 12.083 3.04199H9.6663C9.25209 3.04199 8.9163 3.37778 8.9163 3.79199V4.04199ZM9.20837 8.00033C9.62259 8.00033 9.95837 8.33611 9.95837 8.75033V13.7503C9.95837 14.1645 9.62259 14.5003 9.20837 14.5003C8.79416 14.5003 8.45837 14.1645 8.45837 13.7503V8.75033C8.45837 8.33611 8.79416 8.00033 9.20837 8.00033ZM13.2917 8.75033C13.2917 8.33611 12.9559 8.00033 12.5417 8.00033C12.1275 8.00033 11.7917 8.33611 11.7917 8.75033V13.7503C11.7917 14.1645 12.1275 14.5003 12.5417 14.5003C12.9559 14.5003 13.2917 14.1645 13.2917 13.7503V8.75033Z" fill=""/>
                      </svg>
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</section>
