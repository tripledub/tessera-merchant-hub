<section class="mt-10 border-t border-gray-200 pt-8">
  <div class="sm:flex sm:items-center sm:justify-between gap-4">
    <div>
      <h2 class="text-lg font-semibold text-gray-900">API credentials</h2>
      <p class="mt-1 text-sm text-gray-500">
        Per-shop keys for integrating with tessera-core. Secret keys are shown only once at generation.
      </p>
    </div>
    <% if ShopPolicy.new(current_user, shop).generate_credential? %>
      <%= button_to "Generate credentials",
            shop_credential_path(shop),
            method: :post,
            class: "btn-primary mt-4 sm:mt-0",
            data: { turbo_confirm: "Generate new API credentials? Any existing active key may need to be rotated in your integration." } %>
    <% end %>
  </div>

  <% if defined?(@credentials_error) && @credentials_error.present? %>
    <p class="mt-4 text-sm text-red-600">Could not load credentials: <%= @credentials_error %></p>
  <% elsif @credentials.blank? %>
    <p class="mt-4 text-sm text-gray-500">No credentials yet. Generate a pair to start integrating.</p>
  <% else %>
    <div class="mt-4 overflow-x-auto -mx-4 sm:mx-0">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Public key</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Signing</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Created</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @credentials.each do |cred| %>
            <tr>
              <td class="px-4 py-3 text-sm font-mono text-gray-900"><%= cred["pk"] %></td>
              <td class="px-4 py-3 text-sm text-gray-700"><%= cred["status"] %></td>
              <td class="px-4 py-3 text-sm text-gray-700"><%= cred["signing_required"] ? "Required" : "Optional" %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= cred["created"].presence || "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</section>
