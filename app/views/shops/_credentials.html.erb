<section class="mt-8 border-t border-gray-200 pt-8">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-base font-semibold text-gray-900"><%= t('.title') %></h2>
      <p class="mt-0.5 text-theme-sm text-gray-500">
        <%= t('.subtitle') %>
      </p>
    </div>
    <% if ShopPolicy.new(current_user, shop).generate_credential? %>
      <%= button_to t('.generate'),
            shop_credential_path(shop),
            method: :post,
            class: "btn-primary shrink-0",
            data: { turbo_confirm: t('.generate_confirm') } %>
    <% end %>
  </div>

  <% if defined?(@credentials_error) && @credentials_error.present? %>
    <p class="mt-4 text-theme-sm text-error-600"><%= t('.load_error', message: @credentials_error) %></p>
  <% elsif @credentials.blank? %>
    <p class="mt-4 text-theme-sm text-gray-500"><%= t('.no_credentials') %></p>
  <% else %>
    <div class="mt-4 card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.table.public_key') %></th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.table.status') %></th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.table.signing') %></th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.table.created') %></th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.table.last_used') %></th>
              <th class="relative px-4 py-3"><span class="sr-only"><%= t('.table.actions') %></span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            <% @credentials.each do |cred| %>
              <% revoked = cred["status"].to_s == "revoked" %>
              <% credential_id = cred["id"].presence || cred["pk"] %>
              <tr>
                <td class="px-4 py-3 text-theme-sm font-mono text-gray-900"><%= cred["pk"] %></td>
                <td class="px-4 py-3">
                  <span class="<%= revoked ? 'badge badge-gray' : 'badge badge-success' %>">
                    <%= cred["status"].presence&.titleize || t('.table.unknown_status') %>
                  </span>
                </td>
                <td class="px-4 py-3 text-theme-sm text-gray-700">
                  <%= cred["signing_required"] ? t('.table.signing_required') : t('.table.signing_optional') %>
                </td>
                <td class="px-4 py-3 text-theme-sm text-gray-500"><%= cred["created"].presence || "—" %></td>
                <td class="px-4 py-3 text-theme-sm text-gray-500"><%= cred["last_used"].presence || "—" %></td>
                <td class="px-4 py-3 text-right">
                  <% if !revoked && ShopPolicy.new(current_user, shop).revoke_credential? %>
                    <%= button_to t('.revoke'),
                          shop_credential_revoke_path(shop, credential_id),
                          method: :delete,
                          class: "table-action text-error-600 hover:text-error-700",
                          data: { turbo_confirm: t('.revoke_confirm', pk: cred['pk']) } %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</section>
