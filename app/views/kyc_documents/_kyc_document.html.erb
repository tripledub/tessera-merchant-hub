<div class="flex items-center justify-between rounded-md border border-gray-200 px-4 py-3 text-theme-sm">
  <div class="flex items-center gap-3 min-w-0">
    <svg class="h-5 w-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
    </svg>
    <div class="min-w-0">
      <p class="font-medium text-gray-900 truncate"><%= document.file.filename %></p>
      <div class="flex items-center gap-2 mt-0.5">
        <% if document.kyc_principal %>
          <span class="text-xs text-gray-500"><%= document.kyc_principal.name %></span>
          <% if document.match_method == "fuzzy" %>
            <span class="inline-flex items-center rounded-full bg-yellow-100 px-1.5 py-0.5 text-xs font-medium text-yellow-700">
              <%= t("kyc_documents.match_method.fuzzy") %>
            </span>
          <% end %>
          <% if document.kyc_principal.unconfirmed? %>
            <span class="inline-flex items-center rounded-full bg-orange-100 px-1.5 py-0.5 text-xs font-medium text-orange-700">
              <%= t("kyc_documents.principal_status.unconfirmed") %>
            </span>
          <% end %>
        <% else %>
          <span class="text-xs text-gray-400 italic"><%= t("kyc_documents.unlinked") %></span>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3 flex-shrink-0">
    <% if document.kyc_principal && (document.kyc_principal.unconfirmed? || document.match_method == "fuzzy") %>
      <% if policy(document).confirm_match? %>
        <%= button_to t("kyc_documents.confirm"), confirm_match_kyc_document_path(document),
              method: :patch,
              class: "text-xs text-green-700 hover:underline bg-transparent border-0 p-0 cursor-pointer font-medium" %>
      <% end %>
      <% if policy(document).reject_match? %>
        <%= button_to t("kyc_documents.reject"), reject_match_kyc_document_path(document),
              method: :patch,
              class: "text-xs text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer font-medium" %>
      <% end %>
    <% end %>

    <% case document.status %>
    <% when "pending" %>
      <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">
        <%= t("kyc_documents.status.pending") %>
      </span>
    <% when "processing" %>
      <span class="inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700">
        <%= t("kyc_documents.status.processing") %>
      </span>
    <% when "complete" %>
      <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">
        <%= t("kyc_documents.status.complete") %>
      </span>
    <% when "error" %>
      <span class="inline-flex items-center rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-700">
        <%= t("kyc_documents.status.error") %>
      </span>
    <% end %>
  </div>
</div>
