<%= render "layouts/auth_card", title: "Sign in to MerchantHub" do %>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="space-y-5">
      <div>
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "form-input", placeholder: "you@example.com" %>
      </div>
      <div>
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, autocomplete: "current-password",
              class: "form-input", placeholder: "••••••••" %>
      </div>
      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-brand-600" %>
          <%= f.label :remember_me, class: "text-sm text-gray-600" %>
        </div>
      <% end %>
      <%= f.submit "Sign in", class: "btn-primary w-full" %>
    </div>
  <% end %>
  <div class="mt-5 space-y-2 text-center text-sm text-gray-500">
    <% if devise_mapping.recoverable? && controller_name != "passwords" %>
      <p><%= link_to "Forgot your password?", new_password_path(resource_name),
               class: "text-brand-600 hover:text-brand-700 hover:underline" %></p>
    <% end %>
    <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) %>
      <p><%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name),
               class: "text-brand-600 hover:text-brand-700 hover:underline" %></p>
    <% end %>
    <% if devise_mapping.confirmable? && resource_class.reconfirmable %>
      <p><%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name),
               class: "text-brand-600 hover:text-brand-700 hover:underline" %></p>
    <% end %>
  </div>
<% end %>
