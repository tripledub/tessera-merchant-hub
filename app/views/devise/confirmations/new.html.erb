<%= render "layouts/auth_card", title: "Resend confirmation" do %>
  <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post }) do |f| %>
    <div class="space-y-5">
      <div>
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "form-input", placeholder: "you@example.com" %>
      </div>
      <%= f.submit "Resend confirmation instructions", class: "btn-primary w-full" %>
    </div>
  <% end %>
  <div class="mt-5 text-center">
    <%= link_to "Back to sign in", new_session_path(resource_name),
          class: "text-sm text-brand-600 hover:text-brand-700 hover:underline" %>
  </div>
<% end %>
