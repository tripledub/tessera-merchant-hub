<%= turbo_stream.update "onboarding_upload_status" do %>
  <p class="text-xs <%= @type == :success ? "text-success-600 dark:text-success-400" : "text-error-600 dark:text-error-400" %>">
    <%= @message %>
  </p>
<% end %>

<% if @bot_message %>
  <%= turbo_stream.append "onboarding_messages" do %>
    <%= render "onboarding/conversations/message", message: @bot_message %>
  <% end %>
<% end %>
