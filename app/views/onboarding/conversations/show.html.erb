<% content_for :title, "KYC onboarding" %>

<%= turbo_stream_from @onboarding_session %>

<section
  class="flex h-[calc(100vh-8.5rem)] w-full flex-col overflow-hidden rounded-lg border border-gray-200 bg-white shadow-theme-xs dark:border-gray-800 dark:bg-gray-900"
  data-controller="onboarding-chat">
  <header class="flex flex-wrap items-center justify-between gap-3 border-b border-gray-200 px-4 py-4 dark:border-gray-800 sm:px-6">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-brand-600 dark:text-brand-400">KYC onboarding</p>
      <h1 class="mt-1 text-xl font-semibold text-gray-900 dark:text-white">Welcome</h1>
    </div>
    <%= render "onboarding/conversations/stage_badge", session: @onboarding_session %>
  </header>

  <%= render "onboarding/conversations/progress", session: @onboarding_session %>

  <div
    id="onboarding_messages"
    class="flex-1 space-y-5 overflow-y-auto px-4 py-6 dark:bg-gray-950/30 sm:px-6"
    data-onboarding-chat-target="messages">
    <% if @messages.any? %>
      <%= render partial: "onboarding/conversations/message", collection: @messages, as: :message %>
    <% else %>
      <%= render "onboarding/conversations/message",
            message: @onboarding_session.onboarding_messages.build(
              role: :bot,
              content: "Welcome. I’ll guide you through the KYC onboarding questions and keep track of your progress as we go.",
              stage: @onboarding_session.current_stage,
              created_at: Time.current
            ) %>
    <% end %>
  </div>

  <div
    id="onboarding_typing"
    class="hidden border-t border-gray-100 px-4 py-3 dark:border-gray-800 sm:px-6"
    data-onboarding-chat-target="typing">
    <div class="flex items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
      <span class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-100 text-xs font-semibold text-gray-500 dark:bg-gray-800 dark:text-gray-300">AI</span>
      <span class="inline-flex items-center gap-1">
        <span class="h-2 w-2 rounded-full bg-gray-400"></span>
        <span class="h-2 w-2 rounded-full bg-gray-400"></span>
        <span class="h-2 w-2 rounded-full bg-gray-400"></span>
      </span>
    </div>
  </div>

  <%= form_with url: portal_onboarding_documents_path,
        method: :post,
        multipart: true,
        class: "hidden",
        data: {
          turbo_stream: true,
          action: "turbo:submit-start->onboarding-chat#uploadStart turbo:submit-end->onboarding-chat#uploadEnd"
        } do %>
    <input
      id="onboarding_document_upload"
      type="file"
      name="kyc_document[files][]"
      multiple
      accept="image/*,application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/csv"
      data-onboarding-chat-target="uploadInput"
      data-action="change->onboarding-chat#submitUpload" />
  <% end %>

  <%= render "onboarding/conversations/composer", session: @onboarding_session %>
</section>
