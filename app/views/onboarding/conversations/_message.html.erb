<% applicant_message = message.applicant? %>

<div class="flex <%= applicant_message ? "justify-end" : "justify-start" %>">
  <div class="flex max-w-[85%] items-end gap-3 sm:max-w-[72%] <%= applicant_message ? "flex-row-reverse" : "" %>">
    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full <%= applicant_message ? "bg-brand-500 text-white" : "bg-gray-100 text-gray-500 dark:bg-gray-800 dark:text-gray-300" %>">
      <% if applicant_message %>
        <span class="text-xs font-semibold">You</span>
      <% else %>
        <span class="text-xs font-semibold">AI</span>
      <% end %>
    </div>

    <div>
      <div class="rounded-2xl px-4 py-3 text-sm leading-6 <%= applicant_message ? "rounded-br-sm bg-brand-500 text-white" : "rounded-bl-sm bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-100" %>">
        <%= simple_format(message.content, {}, wrapper_tag: "div") %>
      </div>
      <% if message.created_at.present? %>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-500 <%= applicant_message ? "text-right" : "" %>">
          <%= l(message.created_at, format: :short) %>
        </p>
      <% end %>
    </div>
  </div>
</div>
