<% content_for :title, "Payment #{@payment.id}" %>

<div class="max-w-4xl">
  <div class="mb-6">
    <%= link_to "← Back to payments", payments_path, class: "inline-flex items-center min-h-11 text-sm text-indigo-600 hover:text-indigo-900" %>
  </div>

  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">Payment</h1>
      <p class="mt-1 text-sm font-mono text-gray-500"><%= @payment.id %></p>
    </div>
    <%= render partial: "payments/status_badge", locals: { status: @payment.status } %>
  </div>

  <dl class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div class="bg-gray-50 rounded-lg px-4 py-4">
      <dt class="text-xs font-medium text-gray-500 uppercase">Amount</dt>
      <dd class="mt-1 text-lg font-semibold text-gray-900">
        <%= number_to_currency(@payment.amount / 100.0, unit: @payment.currency + " ") %>
      </dd>
    </div>

    <div class="bg-gray-50 rounded-lg px-4 py-4">
      <dt class="text-xs font-medium text-gray-500 uppercase">Shop</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @payment.shop_id %></dd>
    </div>

    <% if @payment.merchant_reference.present? %>
      <div class="bg-gray-50 rounded-lg px-4 py-4">
        <dt class="text-xs font-medium text-gray-500 uppercase">Merchant Reference</dt>
        <dd class="mt-1 text-sm font-mono text-gray-900"><%= @payment.merchant_reference %></dd>
      </div>
    <% end %>

    <div class="bg-gray-50 rounded-lg px-4 py-4">
      <dt class="text-xs font-medium text-gray-500 uppercase">Created</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @payment.inserted_at&.strftime("%d %b %Y at %H:%M UTC") %></dd>
    </div>

    <div class="bg-gray-50 rounded-lg px-4 py-4 sm:col-span-2">
      <dt class="text-xs font-medium text-gray-500 uppercase">Idempotency Key</dt>
      <dd class="mt-1 text-sm font-mono text-gray-900 break-all"><%= @payment.idempotency_key %></dd>
    </div>
  </dl>

  <%# Actions %>
  <% if PaymentPolicy.new(current_user, @payment).refund? %>
    <div class="mt-6 flex flex-col gap-3 sm:flex-row">
      <% if @payment.status == "succeeded" %>
        <%= button_to "Refund", refund_payment_path(@payment.id),
              method: :post,
              params: { amount: @payment.amount },
              data: { turbo_confirm: "Submit a full refund of #{number_to_currency(@payment.amount / 100.0, unit: @payment.currency + ' ')}?" },
              class: "btn-danger w-full sm:w-auto" %>
      <% end %>
      <% if @payment.status == "authorized" %>
        <%= button_to "Void", void_payment_path(@payment.id),
              method: :post,
              data: { turbo_confirm: "Void this authorisation?" },
              class: "btn-warning w-full sm:w-auto" %>
      <% end %>
    </div>
  <% end %>

  <%# Tab links %>
  <div class="mt-8 border-b border-gray-200">
    <nav class="-mb-px flex gap-6">
      <span class="border-b-2 border-indigo-500 inline-flex items-center min-h-11 text-sm font-medium text-indigo-600">Details</span>
      <%= link_to "Timeline", payment_timeline_path(@payment.id), class: "border-b-2 border-transparent inline-flex items-center min-h-11 text-sm font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300" %>
    </nav>
  </div>
</div>
