<%# Renders a TailAdmin badge for a payment status string.
    Usage: render "payments/status_badge", status: payment.status %>
<%
  badge_class = {
    "succeeded" => "badge badge-success",
    "failed"    => "badge badge-error",
    "pending"   => "badge badge-warning",
    "refunded"  => "badge badge-info",
    "voided"    => "badge badge-gray"
  }.fetch(status.to_s, "badge badge-gray")
%>
<span class="<%= badge_class %>"><%= status.to_s.humanize %></span>
