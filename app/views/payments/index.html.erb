<% content_for :title, "Payments" %>

<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold text-gray-900">Payments</h1>
    </div>
  </div>

  <%# Filter bar %>
  <%= form_with url: payments_path, method: :get, class: "mt-4 flex gap-3 items-end" do |f| %>
    <div>
      <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :status,
            [["All", ""], ["Succeeded", "succeeded"], ["Failed", "failed"], ["Pending", "pending"], ["Refunded", "refunded"]],
            { selected: params[:status] },
            class: "mt-1 block rounded-md border-gray-300 shadow-sm text-sm" %>
    </div>
    <%= f.submit "Filter", class: "px-4 py-2 bg-indigo-600 text-white text-sm rounded-md hover:bg-indigo-700" %>
    <% if params[:status].present? %>
      <%= link_to "Clear", payments_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
    <% end %>
  <% end %>

  <%# Table %>
  <div class="mt-6 overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
          <% if current_user.psp_role? %>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Shop</th>
          <% end %>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
          <th class="relative px-4 py-3"><span class="sr-only">View</span></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @payments.each do |payment| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-sm font-mono text-gray-900 truncate max-w-xs"><%= payment.id %></td>
            <% if current_user.psp_role? %>
              <td class="px-4 py-3 text-sm text-gray-500"><%= payment.shop_id %></td>
            <% end %>
            <td class="px-4 py-3 text-sm text-gray-900">
              <%= number_to_currency(payment.amount / 100.0, unit: payment.currency + " ") %>
            </td>
            <td class="px-4 py-3 text-sm">
              <%= render partial: "payments/status_badge", locals: { status: payment.status } %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= payment.inserted_at&.strftime("%d %b %Y %H:%M") %></td>
            <td class="px-4 py-3 text-sm text-right">
              <%= link_to "View", payment_path(payment.id), class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
            </td>
          </tr>
        <% end %>
        <% if @payments.empty? %>
          <tr>
            <td colspan="<%= current_user.psp_role? ? 6 : 5 %>" class="px-4 py-8 text-center text-sm text-gray-500">
              No payments found.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Pagination %>
  <% if @pagy.pages > 1 %>
    <div class="mt-4 flex justify-center text-sm">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
