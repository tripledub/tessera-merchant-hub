<% content_for :title, t('.page_title') %>

<div class="max-w-2xl">
  <%# Page header %>
  <div class="mb-6">
    <h1 class="text-xl font-semibold text-gray-900"><%= t('.title') %></h1>
    <p class="mt-0.5 text-theme-sm text-gray-500">
      <%= t('.subtitle') %>
    </p>
  </div>

  <div class="card">
    <%= form_with url: merchants_path, method: :post, class: "space-y-8" do |f| %>

      <section class="space-y-4">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.sections.merchant') %></h2>
        <div>
          <%= label_tag "merchant[name]", t('.fields.name'), class: "form-label" %>
          <%= text_field_tag "merchant[name]", params.dig(:merchant, :name), class: "form-input mt-1" %>
        </div>
        <div>
          <%= label_tag "merchant[company_name]", t('.fields.company_name'), class: "form-label" %>
          <%= text_field_tag "merchant[company_name]", params.dig(:merchant, :company_name),
                class: "form-input mt-1" %>
        </div>
        <div>
          <%= label_tag "merchant[country]", t('.fields.country'), class: "form-label" %>
          <%= text_field_tag "merchant[country]", params.dig(:merchant, :country),
                maxlength: 2, class: "form-input mt-1" %>
        </div>
      </section>

      <section class="space-y-4 border-t border-gray-200 pt-6">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.sections.first_shop') %></h2>
        <div>
          <%= label_tag "shop[name]", t('.fields.shop_name'), class: "form-label" %>
          <%= text_field_tag "shop[name]", params.dig(:shop, :name), class: "form-input mt-1" %>
        </div>
        <div>
          <%= label_tag "shop[country]", t('.fields.shop_territory'), class: "form-label" %>
          <%= text_field_tag "shop[country]", params.dig(:shop, :country),
                maxlength: 2, class: "form-input mt-1" %>
        </div>
      </section>

      <section class="space-y-4 border-t border-gray-200 pt-6">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500"><%= t('.sections.first_admin') %></h2>
        <div>
          <%= label_tag "admin[email]", t('.fields.admin_email'), class: "form-label" %>
          <p class="text-xs text-gray-500 mt-0.5"><%= t('.fields.admin_email_hint') %></p>
          <%= email_field_tag "admin[email]", params.dig(:admin, :email), class: "form-input mt-1" %>
        </div>
      </section>

      <div class="flex flex-col gap-3 border-t border-gray-200 pt-6 sm:flex-row">
        <%= f.submit t('.submit'), class: "btn-primary w-full sm:w-auto" %>
        <%= link_to t('.cancel'), authenticated_root_path, class: "btn-secondary w-full sm:w-auto" %>
      </div>

    <% end %>
  </div>
</div>
