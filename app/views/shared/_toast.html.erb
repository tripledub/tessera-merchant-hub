<div id="toast_<%= SecureRandom.hex(4) %>"
     data-controller="toast"
     data-toast-dismiss-after-value="<%= local_assigns[:dismiss_after] || 5000 %>"
     class="flex w-full max-w-sm items-center justify-between gap-3 rounded-md border-b-4 bg-white p-3 shadow-lg transition-all duration-300 translate-x-full opacity-0 dark:bg-[#1E2634]
       <%= case local_assigns[:type]&.to_s
           when 'success' then 'border-success-500'
           when 'error' then 'border-error-500'
           when 'warning' then 'border-warning-500'
           else 'border-blue-light-500'
           end %>">
  <div class="flex items-center gap-3">
    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg
      <%= case local_assigns[:type]&.to_s
          when 'success' then 'bg-success-50 text-success-500 dark:bg-success-500/15'
          when 'error' then 'bg-error-50 text-error-500 dark:bg-error-500/15'
          when 'warning' then 'bg-warning-50 text-warning-600 dark:bg-warning-500/15 dark:text-orange-400'
          else 'bg-blue-light-50 text-blue-light-500 dark:bg-blue-light-500/15'
          end %>">
      <% case local_assigns[:type]&.to_s %>
      <% when 'success' %>
        <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M3.7 12a8.3 8.3 0 1 1 16.6 0 8.3 8.3 0 0 1-16.6 0ZM12 1.9a10.1 10.1 0 1 0 0 20.2 10.1 10.1 0 0 0 0-20.2Zm3.62 8.84a.9.9 0 0 0-1.27-1.27l-3.16 3.16-1.54-1.54a.9.9 0 0 0-1.27 1.27l2.17 2.17a.9.9 0 0 0 1.27 0l3.8-3.8Z" fill=""/>
        </svg>
      <% when 'error' %>
        <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M20.35 12a8.35 8.35 0 1 1-16.7 0 8.35 8.35 0 0 1 16.7 0ZM12 22.15a10.15 10.15 0 1 0 0-20.3 10.15 10.15 0 0 0 0 20.3Zm1-5.68a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM12 6.63a.75.75 0 0 1 .75.75v5.68a.75.75 0 0 1-1.5 0V7.38a.75.75 0 0 1 .75-.75Z" fill=""/>
        </svg>
      <% when 'warning' %>
        <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M13.95 3.88c-.87-1.5-3.03-1.5-3.9 0L2.55 16.88c-.87 1.5.22 3.37 1.95 3.37h15.01c1.73 0 2.82-1.88 1.95-3.37L13.95 3.88Zm-2.6.75a1 1 0 0 1 1.3 0l.02.02 7.5 13c.29.5-.07 1.13-.65 1.13H4.5c-.58 0-.94-.62-.65-1.13l7.5-13ZM12 8.56a.75.75 0 0 1 .75.75v4.22a.75.75 0 0 1-1.5 0V9.31a.75.75 0 0 1 .75-.75Zm-1 7.52a1 1 0 1 1 2 0 1 1 0 0 1-2 0Z" fill=""/>
        </svg>
      <% else %>
        <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M3.5 12a8.5 8.5 0 1 1 17 0 8.5 8.5 0 0 1-17 0ZM12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm-1 5.53a1 1 0 1 1 2 0 1 1 0 0 1-2 0Zm1 2.66a.75.75 0 0 1 .75.75v5.68a.75.75 0 0 1-1.5 0v-5.68a.75.75 0 0 1 .75-.75Z" fill=""/>
        </svg>
      <% end %>
    </div>
    <p class="text-sm font-medium text-gray-800 dark:text-white/90"><%= message %></p>
  </div>
  <button data-action="click->toast#dismiss" class="flex-shrink-0 text-gray-400 hover:text-gray-800 dark:hover:text-white/90">
    <svg class="fill-current" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path fill-rule="evenodd" clip-rule="evenodd" d="M6.04 16.54a1 1 0 0 0 1.42 1.42L12 13.41l4.54 4.54a1 1 0 0 0 1.42-1.41L13.41 12l4.54-4.54a1 1 0 0 0-1.41-1.41L12 10.59 7.46 6.04a1 1 0 0 0-1.42 1.42L10.59 12l-4.55 4.54Z" fill=""/>
    </svg>
  </button>
</div>
