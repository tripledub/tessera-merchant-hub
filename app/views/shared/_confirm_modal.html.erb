<div id="confirm-modal"
     class="fixed inset-0 z-[99999] hidden flex items-center justify-center p-5 overflow-y-auto">
  <div class="fixed inset-0 bg-gray-400/50 backdrop-blur-sm"></div>
  <div class="relative w-full max-w-md rounded-2xl bg-white p-6 shadow-xl dark:bg-gray-900">
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-warning-50 dark:bg-warning-500/15">
        <svg class="h-6 w-6 text-warning-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
        </svg>
      </div>
      <h4 class="mb-2 text-lg font-semibold text-gray-800 dark:text-white/90">
        Are you sure?
      </h4>
      <p id="confirm-modal-message" class="text-sm text-gray-500 dark:text-gray-400">
      </p>
    </div>
    <div class="mt-6 flex items-center justify-center gap-3">
      <button id="confirm-modal-cancel" type="button"
              class="flex w-full justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 shadow-theme-xs hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-white/[0.03] sm:w-auto sm:min-w-[120px]">
        Cancel
      </button>
      <button id="confirm-modal-confirm" type="button"
              class="flex w-full justify-center rounded-lg bg-brand-500 px-4 py-2.5 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-600 sm:w-auto sm:min-w-[120px]">
        Confirm
      </button>
    </div>
  </div>
</div>
