<% content_for :title, "Timeline — Payment #{@payment.id}" %>

<div class="px-4 sm:px-6 lg:px-8 max-w-4xl">
  <div class="mb-6">
    <%= link_to "← Back to payment", payment_path(@payment.id), class: "text-sm text-indigo-600 hover:text-indigo-900" %>
  </div>

  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">Payment Timeline</h1>
      <p class="mt-1 text-sm font-mono text-gray-500"><%= @payment.id %></p>
    </div>
    <%= render partial: "payments/status_badge", locals: { status: @payment.status } %>
  </div>

  <%# Tab nav %>
  <div class="mt-6 border-b border-gray-200">
    <nav class="-mb-px flex gap-6">
      <%= link_to "Details", payment_path(@payment.id),
            class: "border-b-2 border-transparent pb-3 text-sm font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300" %>
      <span class="border-b-2 border-indigo-500 pb-3 text-sm font-medium text-indigo-600">Timeline</span>
    </nav>
  </div>

  <%# Audit event timeline %>
  <div class="mt-6">
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-4">Events</h2>

    <% if @audit_events.empty? %>
      <p class="text-sm text-gray-500">No events recorded for this payment.</p>
    <% else %>
      <ol class="relative border-l border-gray-200 ml-3">
        <% @audit_events.each do |event| %>
          <li class="mb-6 ml-6">
            <span class="absolute -left-2 flex h-4 w-4 items-center justify-center rounded-full
              <%= event.outcome == 'success' ? 'bg-green-100 ring-2 ring-green-400' : 'bg-red-100 ring-2 ring-red-400' %>">
            </span>
            <div class="flex items-center gap-3">
              <span class="text-sm font-medium text-gray-900"><%= event.event_type.humanize %></span>
              <span class="text-xs px-2 py-0.5 rounded-full
                <%= event.actor == 'system' ? 'bg-gray-100 text-gray-600' : 'bg-blue-100 text-blue-700' %>">
                <%= event.actor %>
              </span>
              <span class="text-xs px-2 py-0.5 rounded-full
                <%= event.outcome == 'success' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                <%= event.outcome %>
              </span>
            </div>
            <time class="mt-1 text-xs text-gray-500">
              <%= event.occurred_at&.strftime("%d %b %Y at %H:%M:%S UTC") %>
            </time>
            <% if event.metadata.present? && current_user.psp_role? %>
              <details class="mt-1">
                <summary class="text-xs text-gray-400 cursor-pointer hover:text-gray-600">Metadata</summary>
                <pre class="mt-1 text-xs text-gray-600 bg-gray-50 rounded p-2 overflow-x-auto"><%= JSON.pretty_generate(event.metadata) %></pre>
              </details>
            <% end %>
          </li>
        <% end %>
      </ol>
    <% end %>
  </div>

  <%# Webhook deliveries %>
  <div class="mt-8">
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-4">Webhook Deliveries</h2>

    <% if @webhook_deliveries.empty? %>
      <p class="text-sm text-gray-500">No webhook deliveries recorded.</p>
    <% else %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Attempts</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Last attempt</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Delivered at</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-100">
            <% @webhook_deliveries.each do |delivery| %>
              <tr>
                <td class="px-4 py-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                    <%= delivery.status == 'delivered' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                    <%= delivery.status %>
                  </span>
                </td>
                <td class="px-4 py-2 text-gray-700"><%= delivery.attempts %></td>
                <td class="px-4 py-2 text-gray-500"><%= delivery.last_attempted_at&.strftime("%d %b %Y %H:%M") %></td>
                <td class="px-4 py-2 text-gray-500"><%= delivery.delivered_at&.strftime("%d %b %Y %H:%M") || "—" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
