<%= render "layouts/auth_card", title: t(".title") do %>
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>
    <div class="space-y-5">
      <div>
        <%= f.label :password, t(".new_password"), class: "form-label" %>
        <% if @minimum_password_length %>
          <p class="mb-1 text-xs text-gray-400"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
              class: "form-input", placeholder: "••••••••" %>
      </div>
      <div>
        <%= f.label :password_confirmation, t(".confirm_password"), class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "form-input", placeholder: "••••••••" %>
      </div>
      <%= f.submit t(".submit"), class: "btn-primary w-full" %>
    </div>
  <% end %>
  <div class="mt-5 text-center">
    <%= link_to t(".back_to_sign_in"), new_session_path(resource_name),
          class: "text-sm text-brand-600 hover:text-brand-700 hover:underline" %>
  </div>
<% end %>
