<%= render "layouts/auth_card", title: t("applicant_users.registrations.new.title") do %>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
        html: { data: { controller: "form-validation", action: "submit->form-validation#submitForm" } }) do |f| %>
    <div class="space-y-5">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div>
          <%= f.label :first_name, t("applicant_users.registrations.new.first_name"), class: "form-label" %>
          <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", required: true,
                class: field_class(resource, :first_name), placeholder: "First name" %>
          <%= field_error(resource, :first_name) %>
        </div>
        <div>
          <%= f.label :last_name, t("applicant_users.registrations.new.last_name"), class: "form-label" %>
          <%= f.text_field :last_name, autocomplete: "family-name", required: true,
                class: field_class(resource, :last_name), placeholder: "Last name" %>
          <%= field_error(resource, :last_name) %>
        </div>
      </div>
      <div>
        <%= f.label :email, t("applicant_users.registrations.new.email"), class: "form-label" %>
        <%= f.email_field :email, autocomplete: "email", required: true,
              class: field_class(resource, :email), placeholder: "you@example.com" %>
        <%= field_error(resource, :email) %>
      </div>
      <div>
        <%= f.label :password, t("applicant_users.registrations.new.password"), class: "form-label" %>
        <% if @minimum_password_length %>
          <p class="mb-1 text-xs text-gray-400"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
        <div data-controller="password-toggle" class="relative">
          <%= f.password_field :password, autocomplete: "new-password", required: true,
                minlength: @minimum_password_length || 6,
                class: "#{field_class(resource, :password)} pr-11",
                placeholder: "••••••••",
                data: { password_toggle_target: "input" } %>
          <button type="button" data-action="password-toggle#toggle"
                  class="absolute top-1/2 right-4 -translate-y-1/2 text-gray-500 dark:text-gray-400">
            <svg data-password-toggle-target="showIcon" class="hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <svg data-password-toggle-target="hideIcon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>
            </svg>
          </button>
        </div>
        <%= field_error(resource, :password) %>
      </div>
      <div>
        <%= f.label :password_confirmation, t("applicant_users.registrations.new.password_confirmation"), class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true,
              class: field_class(resource, :password_confirmation), placeholder: "••••••••" %>
        <%= field_error(resource, :password_confirmation) %>
      </div>
      <%= f.submit t("applicant_users.registrations.new.submit"), class: "btn-primary w-full" %>
    </div>
  <% end %>
  <div class="mt-5 text-center text-sm text-gray-500">
    <p><%= t("applicant_users.registrations.new.already_have_account") %>
      <%= link_to t("applicant_users.registrations.new.sign_in_link"), new_session_path(resource_name),
            class: "text-brand-600 hover:text-brand-700 hover:underline" %></p>
  </div>
<% end %>
